# Gradio Universal AI WebUI — 环境变量配置
# 复制此文件为 .env 后修改:  cp .env.example .env

# ── WebUI ──
WEBUI_PORT=7860
WEBUI_TAG=latest
# WEBUI_AUTH_TOKEN=changeme           # 设置后启用 LAN 认证（可选）

# ── Stable Diffusion ──
SD_PORT=17860
SD_TAG=latest
SD_BACKEND=diffusers                   # diffusers | openai | automatic1111
SD_MODEL_ID=runwayml/stable-diffusion-v1-5
SD_DEVICE=cuda:0

# ── Qwen3 ASR ──
QWEN3_PORT=8100
QWEN3_TAG=latest
QWEN3_CHECKPOINT=/models/qwen3-asr
QWEN3_DEVICE=cuda:0

# ── WhisperX ──
WHISPERX_PORT=8200
WHISPERX_TAG=latest
WHISPERX_MODEL=large-v3
WHISPERX_DEVICE=cuda:0

# ── FastWhisper (CTranslate2) ──
FW_PORT=8300
FW_TAG=latest
FW_MODEL=large-v3
FW_DEVICE=cuda:0
