# Qwen3 ASR 服务的 Dockerfile
FROM python:3.11-slim-bookworm

RUN apt-get update && apt-get install -y --no-install-recommends \
    libsndfile1 ffmpeg curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

RUN pip install --no-cache-dir torch transformers accelerate

COPY services/qwen3_asr_service.py /app/service.py

HEALTHCHECK --interval=30s --timeout=10s --retries=3 \
    CMD curl -sf http://localhost:${ASR_PORT:-8100}/health || exit 1

EXPOSE 8100

ENV PYTHONUNBUFFERED=1
CMD ["python", "/app/service.py", "--port", "${ASR_PORT:-8100}"]
